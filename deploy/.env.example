# Oracle App — deployment secrets
#
# Copy this file to `.env` on the KVM 2 server (in the same directory as
# compose.yml) and fill in real values. `.env` is gitignored and MUST NOT be
# committed.
#
# ─── ORACLE_BASIC_AUTH_USERS ──────────────────────────────────────────────────
#
# HTTP Basic Auth users for the Traefik middleware protecting oracle.aptoworks.cloud.
# Format: user:hash  (multiple users comma-separated)
#
# Generate a bcrypt hash locally on your Mac:
#
#   htpasswd -nbB nick 'your-password-here'
#
# Paste the FULL output of that command as-is. Example (do NOT use this hash):
#
#   ORACLE_BASIC_AUTH_USERS=nick:$2y$05$Lx3kKJqHbEQvDh8M.NUVYeO3qvG/xYh.YQtLzR1z1uI0EzBqXMNAi
#
# Notes:
# - bcrypt hashes contain `$` characters. Docker Compose does NOT re-interpret
#   values read from `.env` files, so a single `$` is correct here. Do NOT
#   escape as `$$` — that's only needed when the hash is written directly into
#   compose.yml labels.
# - If you prefer MD5 (less secure but also supported), use `htpasswd -nbm` and
#   paste the output the same way.
# - To add more users later: comma-separate them.
#     ORACLE_BASIC_AUTH_USERS=nick:hash1,bee:hash2,luke:hash3
#
ORACLE_BASIC_AUTH_USERS=nick:REPLACE_ME_WITH_OUTPUT_OF_htpasswd_-nbB

# ─── PENNYWORTH_BASE_URL (Phase 2.B Minimal Chat) ─────────────────────────────
#
# Server-only env var read by the project page loader to fetch chat threads
# from the Pennyworth backend (PRD §7.1, AC-33). Must be reachable from inside
# the Oracle App container — for KVM 2 this is the internal docker network
# hostname `pennyworth:3001`. For local dev use `http://localhost:3001`.
#
# **Port 3001, not 3000** — the Pennyworth service binds on 3001 inside its
# container (verified live 2026-04-07). The Oracle App also binds on 3000, so
# don't get them confused.
#
# Both `oracle` and `pennyworth` services must be on the `root_default` docker
# network for the internal hostname to resolve. Verify with:
#   docker network inspect root_default --format '{{range .Containers}}{{.Name}} {{end}}'
#
# If unset or unreachable, the Chats tab degrades to an inline error state but
# the rest of the project page (SOW, Artifacts, header) still renders normally.
#
PENNYWORTH_BASE_URL=http://pennyworth:3001

# ─── PENNYWORTH_API_TOKEN (Phase 2.B Minimal Chat) ────────────────────────────
#
# Bearer token for Pennyworth's `/api/*` endpoints. Pennyworth gates every
# non-health endpoint with `Authorization: Bearer ${AOL_API_TOKEN}` (the env
# var is named differently on the two sides — `AOL_API_TOKEN` inside Pennyworth,
# `PENNYWORTH_API_TOKEN` here on the consumer side, but the VALUE must match).
#
# Get the value from `/opt/pennyworth/.env` on KVM 2:
#     ssh root@31.220.21.243 'grep ^AOL_API_TOKEN /opt/pennyworth/.env'
#
# If unset, the Chats tab degrades to an inline error state with a clear
# "PENNYWORTH_API_TOKEN is not set" message and the rest of the project page
# still renders normally.
#
PENNYWORTH_API_TOKEN=REPLACE_ME_WITH_AOL_API_TOKEN_FROM_PENNYWORTH_ENV

# ─── Deploy notes ─────────────────────────────────────────────────────────────
#
# This stack expects the following to exist on the KVM 2 host before deploy:
#
# 1. Docker network `root_default` (created by the root Traefik stack).
#    Attached to as `external: true` in compose.yml.
#
# 2. Bind-mount source directory `/opt/oracle/data` containing the ORACLE repo
#    layout at its root (Projects/, Areas/, BRIDGE.md, etc.). ORACLE data sync
#    strategy — cron git pull vs webhook vs sharing Pennyworth's copy — is TBD
#    and tracked as an ORACLE issue for a deploy-time conversation.
#
# 3. DNS: `oracle.aptoworks.cloud` A record → KVM 2 IP (31.220.21.243). Let's
#    Encrypt via Traefik's `mytlschallenge` resolver will issue the cert on
#    first request.
#
# 4. Traefik config already live on KVM 2:
#    - Cert resolver named `mytlschallenge` (matches /root/docker-compose.yml)
#    - Entrypoints `web` (80) and `websecure` (443), with web → websecure redirect
#    - Traefik attached to network `root_default`
